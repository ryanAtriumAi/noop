    "Overnight computed": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcolato durante la notte"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "夜间计算"
          }
        },
        "zh-Hant": {
