    "Acts as a standard Bluetooth heart-rate strap. Pair NOOP from your treadmill, bike or app to see your strap's heart rate there.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Funziona come una normale fascia cardio Bluetooth. Abbina NOOP dal tuo tapis roulant, bici o app per vedere lì la frequenza cardiaca della tua fascia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "作为标准的蓝牙心率手环使用。从你的跑步机、单车或应用中配对 NOOP，即可在那里看到手环的心率。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "作為標準的藍牙心率手環使用。從你的跑步機、單車或應用程式中配對 NOOP，即可在那裡看到手環的心率。"
          }
        }
      }
    },
    "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Akute (7 Tage) vs. chronische (28 Tage) Trainingslast. 0,8–1,3 ist der ideale Bereich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga de entrenamiento aguda (7 días) frente a crónica (28 días). 0,8–1,3 es el rango ideal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Charge d'entraînement aiguë (7 jours) vs chronique (28 jours). 0,8–1,3 est la zone idéale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carico di allenamento acuto (7 giorni) rispetto a cronico (28 giorni). 0,8–1,3 è la fascia ideale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соотношение острой (7-дневной) и хронической (28-дневной) тренировочной нагрузки. Оптимальный коэффициент , 0,8–1,3."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "急性（7 天）与慢性（28 天）训练负荷之比。0.8–1.3 是理想区间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "急性（7 天）與慢性（28 天）訓練負荷之比。0.8–1.3 是理想區間。"
          }
        }
      }
    },
