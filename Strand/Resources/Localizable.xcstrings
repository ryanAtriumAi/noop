        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在哪些方面比手环更薄弱"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在哪些方面比手環更薄弱"
          }
        }
      }
    },
    "WHOOP 4.0 · motion → steps": {
      "localizations": {
