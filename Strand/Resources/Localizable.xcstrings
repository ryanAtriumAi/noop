        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld lettura%2$@ allineate finora, non abbastanza per leggere un andamento (NOOP aspetta %3$lld)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前已有 %1$lld 条读数%2$@对齐 — 还不足以读出趋势（NOOP 需等待 %3$lld 条）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前已有 %1$lld 筆讀數%2$@對齊 — 還不足以讀出趨勢（NOOP 需等待 %3$lld 筆）。"
          }
