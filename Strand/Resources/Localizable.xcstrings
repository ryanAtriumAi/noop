          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自我追踪，而非临床评估。如果低落情绪持续存在，请咨询专业人士 — 你值得获得支持。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
