        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Creazione della tua linea di base. Ancora circa %1$lld %2$@ prima che i tuoi punteggi siano personalizzati."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在构建你的基线。大约还需 %1$lld %2$@，你的评分才会变得个性化。"
