          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay historial de estrés. Importa tu exportación de WHOOP en Fuentes de datos para verlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore d'historique de stress. Importez votre export WHOOP dans Sources de données pour le voir."
          }
        },
        "it": {
