          }
        }
      }
    },
    "%lld readings used · %@ %@ association. This is your own data sitting side by side — it's not a medical finding, and it shows association, not cause.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld readings used · %2$@ %3$@ association. This is your own data sitting side by side — it's not a medical finding, and it shows association, not cause."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld letture usate · associazione %2$@ %3$@. Questi sono i tuoi dati messi a confronto, non è un referto medico e mostra un'associazione, non una causa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用了 %1$lld 条读数 · %2$@ %3$@ 关联。这是你自己的数据并排呈现 — 它不是医学结论，只显示关联，而非因果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用了 %1$lld 筆讀數 · %2$@ %3$@ 關聯。這是你自己的資料並排呈現 — 它不是醫學結論，只顯示關聯，而非因果。"
          }
        }
      }
    },
