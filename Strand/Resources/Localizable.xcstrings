    "Low confidence": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Bassa affidabilità"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "低置信度"
          }
        },
        "zh-Hant": {
