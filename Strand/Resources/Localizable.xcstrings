      }
    },
    "Open-source BLE reverse-engineering work. Thank you.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Open-Source-BLE-Reverse-Engineering-Arbeit. Danke."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open-source BLE reverse-engineering work. Thank you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabajo de ingeniería inversa de BLE de código abierto. Gracias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travail de rétro-ingénierie BLE open-source. Merci."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lavoro open-source di reverse engineering BLE. Grazie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открытая работа по изучению BLE-протокола. Спасибо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开源 BLE 逆向工程工作。谢谢你。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開源 BLE 逆向工程工作。謝謝你。"
          }
        }
      }
    },
    "Opens the Apple Watch setup and Health permission": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre la configurazione dell'Apple Watch e i permessi di Health"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开 Apple Watch 设置和健康权限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開 Apple Watch 設定和健康權限"
          }
        }
      }
    },
    "Opens the Devices screen, where you pair and switch bands.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre la schermata Dispositivi, dove abbini e cambi le fasce."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开「设备」界面，你可以在其中配对和切换手环。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開「裝置」畫面，你可以在其中配對和切換手環。"
          }
        }
      }
    },
    "Opens the GitHub releases page in your browser. NOOP itself makes no network connections , the macOS sandbox has no network entitlement.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnet die GitHub-Releases-Seite in deinem Browser. NOOP selbst stellt keine Netzwerkverbindungen her , die macOS-Sandbox hat keine Netzwerk-Berechtigung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens the GitHub releases page in your browser. NOOP itself makes no network connections , the macOS sandbox has no network entitlement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la página de versiones de GitHub en tu navegador. NOOP en sí no realiza conexiones de red: el sandbox de macOS no tiene permiso de red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre la page des versions GitHub dans votre navigateur. NOOP lui-même n'effectue aucune connexion réseau , le bac à sable macOS n'a pas de droit réseau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre la pagina delle release di GitHub nel tuo browser. NOOP di per sé non effettua alcuna connessione di rete, la sandbox di macOS non ha l'autorizzazione di rete."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откроет страницу релизов GitHub в браузере. Сам NOOP не устанавливает сетевые соединения , у песочницы macOS нет разрешения на доступ к сети."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的浏览器中打开 GitHub 发布页面。NOOP 本身不建立任何网络连接——macOS 沙盒没有网络权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的瀏覽器中打開 GitHub 發布頁面。NOOP 本身不建立任何網路連接——macOS 沙盒沒有網路權限。"
          }
        }
      }
    },
    "Opens workout detail": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre il dettaglio dell'allenamento"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开锻炼详情"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開鍛鍊詳情"
          }
        }
      }
    },
    "Optional": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選"
          }
        }
      }
    },
    "Optional note": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota facoltativa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选备注"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選備註"
          }
        }
      }
    },
    "Optional trackers, off by default. Turn them on to add their cards. Everything stays on %@.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tracker facoltativi, disattivati per impostazione predefinita. Attivali per aggiungere le loro schede. Tutto resta su %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选的追踪器，默认关闭。开启它们以添加其卡片。一切都留在 %@ 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選的追蹤器，預設關閉。開啟它們以新增其卡片。一切都留在 %@ 上。"
          }
        }
      }
    },
    "Optional — adds your VO₂max estimate. The Fitness Age itself doesn't need it. Measure around your middle, at the navel.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo, aggiunge la tua stima del VO₂max. L'Età di fitness in sé non ne ha bisogno. Misura intorno al punto vita, all'altezza dell'ombelico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选 — 会加上你的最大摄氧量估算。体能年龄本身并不需要它。请在腰部、肚脐位置测量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選 — 會加上你的最大攝氧量估算。體能年齡本身並不需要它。請在腰部、肚臍位置測量。"
          }
        }
      }
    },
    "Optional. Add a photo for the avatar in the top-left. Stored only on %@ — NOOP is offline, so it's never uploaded.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo. Aggiungi una foto per l'avatar in alto a sinistra. Memorizzata solo su %@, NOOP è offline, quindi non viene mai caricata."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选。为左上角的头像添加一张照片。仅存储在 %@ 上 — NOOP 是离线的，因此绝不会上传。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選。為左上角的頭像新增一張照片。僅儲存在 %@ 上 — NOOP 是離線的，因此絕不會上傳。"
          }
        }
      }
    },
    "Optional. Stored only on this device.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo. Memorizzato solo su questo dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选。仅存储在这台设备上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選。僅儲存在這台裝置上。"
          }
        }
      }
    },
    "Other metrics (R-R, frames, battery, history) need a full sync.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Altri parametri (R-R, frame, batteria, cronologia) richiedono una sincronizzazione completa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他指标（R-R、帧、电量、历史）需要一次完整同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "其他指標（R-R、幀、電量、歷史）需要一次完整同步。"
          }
        }
      }
    },
