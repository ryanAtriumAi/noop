    "Replace this device's data with one of the backups in your folder. This overwrites current data, so back up first if you're unsure.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisci i dati di questo dispositivo con uno dei backup nella tua cartella. Questo sovrascrive i dati attuali, quindi fai prima un backup se hai dubbi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你文件夹中的某个备份替换这台设备的数据。这会覆盖当前数据，如果你不确定，请先备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
