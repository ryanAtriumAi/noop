    "Charge baseline calibrating. %@, %@. %@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Charge baseline calibrating. %1$@, %2$@. %3$@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrazione della linea di base della carica. %1$@, %2$@. %3$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能量基线校准中。%1$@，%2$@。%3$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "能量基線校準中。%1$@，%2$@。%3$@。"
          }
        }
      }
    },
    "Charge model": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Modello di carica"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能量模型"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "能量模型"
          }
        }
      }
    },
    "Charge weighs your HRV against your personal baseline (~55%%), resting heart rate (~20%%), rest quality (~15%%), respiration (~5%%) and skin-temperature deviation (~5%%). Effort is a 0–%@ cardiovascular load from time in heart-rate zones. Rest is staged from movement and heart rate. Everything is computed here from the strap's raw data — it works for any day NOOP collected raw streams.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La carica pondera la tua HRV rispetto alla tua linea di base personale (~55%%), la frequenza cardiaca a riposo (~20%%), la qualità del riposo (~15%%), la respirazione (~5%%) e la deviazione della temperatura cutanea (~5%%). Lo sforzo è un carico cardiovascolare da 0 a %@ basato sul tempo nelle zone di frequenza cardiaca. Il riposo è suddiviso in fasi a partire dal movimento e dalla frequenza cardiaca. Tutto viene calcolato qui dai dati grezzi della fascia, funziona per qualsiasi giorno in cui NOOP ha raccolto i flussi grezzi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能量会将你的 HRV 与你的个人基线（约 55%%）、静息心率（约 20%%）、休息质量（约 15%%）、呼吸（约 5%%）和皮肤温度偏差（约 5%%）进行加权。消耗是根据在各心率区间的时间得出的 0–%@ 心血管负荷。休息则根据体动和心率分期。一切都在这里根据手环的原始数据计算 — 只要 NOOP 采集到原始数据流的任何一天都适用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "能量會將你的 HRV 與你的個人基線（約 55%%）、靜息心率（約 20%%）、休息品質（約 15%%）、呼吸（約 5%%）和皮膚溫度偏差（約 5%%）進行加權。消耗是根據在各心率區間的時間得出的 0–%@ 心血管負荷。休息則根據體動和心率分期。一切都在這裡根據手環的原始資料計算 — 只要 NOOP 採集到原始資料流的任何一天都適用。"
          }
        }
      }
    },
    "Charge · Effort · Rest": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carica · sforzo · riposo"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能量 · 消耗 · 休息"
