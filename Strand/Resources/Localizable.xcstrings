    "Make this your active strap?": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendere questa la tua fascia attiva?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将此设为你的活跃手环？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
